    <script>
      function setupBalloon(balloonId, popMsgId) {
        const balloon = document.getElementById(balloonId);
        const popMsg = document.getElementById(popMsgId);

        function popBalloon() {
          balloon.style.visibility = 'hidden';
          popMsg.classList.add('show');
          setTimeout(() => {
            popMsg.classList.remove('show');
            setTimeout(() => {
              balloon.style.visibility = '';
            }, 700);
          }, 700);
        }
        balloon.addEventListener('click', popBalloon);
        balloon.addEventListener('touchstart', popBalloon);
      }
      setupBalloon('balloon1', 'popMsg1');
      setupBalloon('balloon2', 'popMsg2');
    </script>
